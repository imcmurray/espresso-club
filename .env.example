# Copy to .env and fill in. .env is git-ignored.

# === Image tag (for prebuilt images from GHCR) ===
# Default "latest" tracks the most recent push to main. Pin to a specific
# git SHA for production: ESPRESSO_TAG=abc1234...
ESPRESSO_TAG=latest

# === LNbits funding source ===
# FakeWallet for dev (no real LN). PhoenixdWallet for production.
LNBITS_BACKEND_WALLET_CLASS=FakeWallet
LNBITS_ADMIN_KEY=
# When using Phoenixd:
PHOENIXD_API_ENDPOINT=http://phoenixd:9740/
PHOENIXD_API_PASSWORD=

# === Phoenixd ===
# Leave empty on first run — Phoenixd will generate and print one. Save it!
# Subsequent runs: paste it back here so the same wallet is restored.
PHOENIX_SEED=

# === Hardware ===
RELAY_DRIVER=simulator   # or "shelly" once the relay is wired
SHELLY_HOST=192.168.1.50
GRINDER_PULSE_SECONDS=30

# === Slack bot (optional) ===
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
